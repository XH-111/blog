{
	email admin@hechenxu.cn
}

hechenxu.cn, www.hechenxu.cn {
	encode gzip zstd

	handle /api/* {
		reverse_proxy app:8000
	}

	handle_path /uploads/* {
		root * /uploads
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
